{
  "manifest_version": 3,
  "name": "Munpia Best Data Extractor",
  "version": "1.1",
  "description": "Extracts top 100 novel data from Munpia and calculates metrics.",
  "permissions": [
    "scripting",
    "tabs",
    "downloads",
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://*.munpia.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.munpia.com/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ]
}
