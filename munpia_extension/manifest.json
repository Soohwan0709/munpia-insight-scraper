{
  "manifest_version": 3,
  "name": "Munpia Insight Scraper",
  "version": "1.0",
  "description": "문피아 작품 통계 분석 및 엑셀 다운로드 도구",
  "permissions": [
    "scripting",
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "*://novel.munpia.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://novel.munpia.com/*"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
